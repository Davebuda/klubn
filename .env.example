# DJ-DiP Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
# For Development (SQLite)
ConnectionStrings__DefaultConnection=Data Source=DJDIP.db

# For Production (PostgreSQL recommended)
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=djdip_prod;Username=djdip_user;Password=your_secure_password

# For SQL Server (optional)
# ConnectionStrings__SqlServerConnection=Server=localhost;Database=DJDiP;User Id=sa;Password=your_secure_password;TrustServerCertificate=True

# JWT Configuration
# IMPORTANT: Generate a new secure key for production!
# Use: openssl rand -base64 64
Jwt__Key=REPLACE_WITH_SECURE_RANDOM_KEY_MIN_32_CHARS
Jwt__Issuer=DJDiP
Jwt__Audience=DJDiP
Jwt__AccessTokenMinutes=120
Jwt__RefreshTokenDays=30

# Admin Seed Account (required for first-time database initialization)
ADMIN_EMAIL=admin@djdip.com
ADMIN_DEFAULT_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# n8n Social Sync ingest shared secret (x-n8n-secret header)
N8N_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET

# CORS Configuration
CORS__AllowedOrigins=http://localhost:3000,http://localhost:5173,https://klubn.com,https://www.klubn.com

# File Upload Configuration
FileUpload__MaxFileSizeBytes=10485760
FileUpload__AllowedExtensions=.jpg,.jpeg,.png,.gif,.mp4,.mov
FileUpload__UploadPath=wwwroot/uploads

# Rate Limiting
RateLimit__PermitLimit=100
RateLimit__Window=1
RateLimit__QueueLimit=0

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning

# Application Settings
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000

# Traefik / SSL (Let's Encrypt)
ACME_EMAIL=your@email.com

# Production URLs
BACKEND_URL=https://api.klubn.com
FRONTEND_URL=https://klubn.com
CORS_ALLOWED_ORIGINS=https://klubn.com,https://www.klubn.com

# Frontend build args (baked in at build time)
VITE_API_URL=https://api.klubn.com/graphql
VITE_WS_URL=wss://api.klubn.com/graphql
VITE_UPLOAD_API_URL=https://api.klubn.com/api/upload

# Email Configuration (for future use)
# Email__Provider=SendGrid
# Email__ApiKey=your_sendgrid_api_key
# Email__FromEmail=noreply@djdip.com
# Email__FromName=DJ-DiP

# Payment Gateway (for future use)
# Stripe__PublishableKey=pk_live_xxxxx
# Stripe__SecretKey=sk_live_xxxxx
# Stripe__WebhookSecret=whsec_xxxxx

# Redis Cache (optional, for scaling)
# Redis__ConnectionString=localhost:6379
# Redis__InstanceName=DJDiP_

# Application Insights / Monitoring
# ApplicationInsights__InstrumentationKey=your_key_here

# Security
# AllowedHosts=yourdomain.com,www.yourdomain.com
